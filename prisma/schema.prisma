// SilentApply MVP Database Schema
// Based on PRD specifications

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  createdAt  DateTime  @default(now()) @map("created_at")
  profiles   Profile[]
  accounts   Account[]
  sessions   Session[]

  @@map("users")
}

model Profile {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  handle         String    @unique
  headline       String?
  roles          String[]
  locationMode   String    @map("location_mode") // remote|hybrid|onsite
  commuteMiles   Int?      @map("commute_miles")
  workAuthJson   Json      @map("work_auth_json")
  availabilityJson Json    @map("availability_json")
  compJson       Json?     @map("comp_json")
  proofLinks     Json[]    @map("proof_links")
  visibilityJson Json      @map("visibility_json")
  published      Boolean   @default(false)
  updatedAt      DateTime  @updatedAt @map("updated_at")
  user           User      @relation(fields: [userId], references: [id])
  resumes        Resume[]
  qaThreads      QAThread[]
  bookings       Booking[]
  availabilityWindows AvailabilityWindow[]
  analyticsEvents AnalyticsEvent[]

  @@map("profiles")
}

// Candidate-defined weekly availability windows used to generate bookable slots.
// Times are minutes-from-midnight in UTC to match the booking API's UTC slots.
model AvailabilityWindow {
  id          String   @id @default(uuid())
  profileId   String   @map("profile_id")
  dayOfWeek   Int      @map("day_of_week")   // 0=Sunday .. 6=Saturday
  startMinute Int      @map("start_minute")  // minutes from 00:00 UTC
  endMinute   Int      @map("end_minute")    // minutes from 00:00 UTC
  createdAt   DateTime @default(now()) @map("created_at")
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("availability_windows")
}

model Resume {
  id         String    @id @default(uuid())
  profileId  String    @map("profile_id")
  fileUrl    String    @map("file_url")
  parsedText String    @map("parsed_text")
  createdAt  DateTime  @default(now()) @map("created_at")
  profile    Profile   @relation(fields: [profileId], references: [id])
  chunks     ResumeChunk[]

  @@map("resumes")
}

model ResumeChunk {
  id        String   @id @default(uuid())
  resumeId  String   @map("resume_id")
  content   String
  embedding Unsupported("extensions.vector")?
  resume    Resume   @relation(fields: [resumeId], references: [id])

  @@map("resume_chunks")
}

model QAThread {
  id        String    @id @default(uuid())
  profileId String    @map("profile_id")
  createdAt DateTime  @default(now()) @map("created_at")
  profile   Profile   @relation(fields: [profileId], references: [id])
  messages  QAMessage[]

  @@map("qa_threads")
}

model QAMessage {
  id         String   @id @default(uuid())
  threadId   String   @map("thread_id")
  role       String   // recruiter|system|candidate
  content    String
  sourcesJson Json    @map("sources_json")
  status     String   // answered|escalated
  createdAt  DateTime @default(now()) @map("created_at")
  thread     QAThread @relation(fields: [threadId], references: [id])

  @@map("qa_messages")
}

model Booking {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  status    String   // open|held|booked
  email     String?
  name      String?
  heldUntil DateTime? @map("held_until")
  createdAt DateTime @default(now()) @map("created_at")
  profile   Profile  @relation(fields: [profileId], references: [id])

  @@map("bookings")
}

model AnalyticsEvent {
  id          String    @id @default(uuid())
  profileId   String?   @map("profile_id")
  eventType   String    @map("event_type")
  metadataJson Json     @map("metadata_json")
  createdAt   DateTime  @default(now()) @map("created_at")
  profile     Profile?  @relation(fields: [profileId], references: [id])

  @@map("analytics_events")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model RateLimit {
  id       String   @id @default(uuid())
  key      String   @unique
  count    Int      @default(0)
  resetAt  DateTime

  @@map("rate_limits")
}
