# ============================================
# SILENTAPPLY ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# --------------------------------------------
# DATABASE (Required)
# --------------------------------------------
# Azure Postgres connection string
# Format: postgresql://<user>:<pass>@<host>:5432/<db>?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/silentapply?sslmode=require

# --------------------------------------------
# REDIS (Required)
# --------------------------------------------
# Azure Cache for Redis connection string
# Format: rediss://:<access_key>@<redis_host>:6380
REDIS_URL=rediss://:your-access-key@your-redis-host.redis.cache.windows.net:6380

# --------------------------------------------
# NEXTAUTH (Required)
# --------------------------------------------
# Base URL for your application
NEXTAUTH_URL=http://localhost:3000

# Secret for NextAuth session encryption (32+ bytes random)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Trust host header (set to true for Azure Container Apps)
AUTH_TRUST_HOST=false

# --------------------------------------------
# EMAIL - AZURE COMMUNICATION SERVICES (Required)
# --------------------------------------------
# ACS SMTP Configuration
# Host: Your ACS SMTP endpoint
EMAIL_SERVER_HOST=your-acs-endpoint.communication.azure.com

# Port: 587 for TLS
EMAIL_SERVER_PORT=587

# User: Your ACS SMTP username
EMAIL_SERVER_USER=your-acs-smtp-username

# Password: Your ACS SMTP password
EMAIL_SERVER_PASSWORD=your-acs-smtp-password

# From address (must be verified in ACS)
EMAIL_FROM=noreply@silentapply.ai

# Optional: ACS Connection String (for direct API usage)
ACS_CONNECTION_STRING=endpoint=https://your-acs-resource.communication.azure.com/;accesskey=your-access-key

# --------------------------------------------
# AZURE BLOB STORAGE (Optional - for resume uploads)
# --------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=resumes

# --------------------------------------------
# STRIPE (Optional - for paid features)
# --------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# --------------------------------------------
# ENVIRONMENT
# --------------------------------------------
NODE_ENV=development

