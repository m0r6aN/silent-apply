# SilentApply — Environment Variables
# Copy to .env.local and fill in values before running.

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/silentapply

# Direct URL for Prisma migrations (optional — same as DATABASE_URL if not using pgbouncer)
DIRECT_URL=postgresql://user:password@host:5432/silentapply

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection string for rate limiting (required)
# Use rediss:// for TLS (Azure Cache for Redis, Upstash, etc.)
REDIS_URL=redis://localhost:6379

# ── Auth (NextAuth) ───────────────────────────────────────────────────────────
# Public base URL of this app (required)
NEXTAUTH_URL=http://localhost:3000

# Secret for NextAuth JWT signing — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# ── Email (SMTP for magic link auth) ─────────────────────────────────────────
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-smtp-user
EMAIL_SERVER_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@silentapply.com

# ── Stripe (optional — only needed if paid tier is active) ───────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID_MONTHLY=price_...
# STRIPE_PRICE_ID_YEARLY=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Keon MCP Gateway (optional — governed AI actions) ────────────────────────
# When KEON_GOVERNANCE_ENABLED=true, Q&A and resume parsing emit governance
# receipts through the Keon MCP Gateway. If not configured, the app falls back
# to local bounded behavior and does not claim Keon governance.
#
# KEON_GOVERNANCE_ENABLED=true
# KEON_MCP_GATEWAY_ENDPOINT=https://keon-mcp-gateway.redrock-24997c6f.eastus2.azurecontainerapps.io
# KEON_MCP_API_KEY=your-api-key
# KEON_MCP_TENANT_ID=your-tenant-id
# KEON_MCP_ACTOR_ID=silentapply-api

# ── SSL (optional) ────────────────────────────────────────────────────────────
# Set to "false" only for local dev with self-signed certs
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
