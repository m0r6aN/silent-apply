# SilentApply — Environment Variables
# Copy to .env.local and fill in values before running.

# ── Database (Neon Postgres) ─────────────────────────────────────────────────
# Pooled connection string used by the app at runtime (required).
# Neon dashboard → Connection Details → "Pooled connection".
DATABASE_URL=postgresql://silentapply_owner:REPLACE_WITH_PASSWORD@ep-placeholder-pooler.us-east-2.aws.neon.tech/silentapply?sslmode=require

# Direct (non-pooled) connection used by Prisma CLI for migrations (required).
# Neon dashboard → Connection Details → uncheck "Pooled connection".
DIRECT_URL=postgresql://silentapply_owner:REPLACE_WITH_PASSWORD@ep-placeholder.us-east-2.aws.neon.tech/silentapply?sslmode=require

# ── Redis (Azure Cache for Redis) ────────────────────────────────────────────
# TLS endpoint on port 6380. From the Azure portal → Access keys / connection.
# Format: rediss://:<primary-access-key>@<name>.redis.cache.windows.net:6380
REDIS_URL=rediss://:REPLACE_WITH_ACCESS_KEY@silentapply-cache.redis.cache.windows.net:6380

# ── Auth (NextAuth) ───────────────────────────────────────────────────────────
# Public base URL of this app (required). In production: https://silentapply.ai
NEXTAUTH_URL=http://localhost:3000

# Secret for NextAuth JWT signing — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# ── Email (Azure Communication Services — resource: ecs-silentapply) ─────────
# Connection string from the ecs-silentapply resource → Keys.
# Used for magic-link sign-in and booking confirmation emails.
ACS_EMAIL_CONNECTION_STRING=endpoint=https://ecs-silentapply.unitedstates.communication.azure.com/;accesskey=REPLACE_WITH_ACCESS_KEY
# Verified sender address (MailFrom on the connected Email Communication domain).
EMAIL_FROM=DoNotReply@silentapply.ai

# ── Resume storage (Azure Blob Storage) ──────────────────────────────────────
# Connection string for the storage account that holds uploaded resumes.
# If unset, resumes fall back to local disk (dev only — not durable in prod).
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=silentapplyblob;AccountKey=REPLACE_WITH_ACCOUNT_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=resumes

# ── Stripe (optional — only needed if paid tier is active) ───────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID_MONTHLY=price_...
# STRIPE_PRICE_ID_YEARLY=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Keon MCP Gateway (optional — governed AI actions) ────────────────────────
# When KEON_GOVERNANCE_ENABLED=true, Q&A and resume parsing emit governance
# receipts through the Keon MCP Gateway. If not configured, the app falls back
# to local bounded behavior and does not claim Keon governance.
#
# KEON_GOVERNANCE_ENABLED=true
# KEON_MCP_GATEWAY_ENDPOINT=https://keon-mcp-gateway.redrock-24997c6f.eastus2.azurecontainerapps.io
# KEON_MCP_API_KEY=your-api-key
# KEON_MCP_TENANT_ID=your-tenant-id
# KEON_MCP_ACTOR_ID=silentapply-api

# ── SSL (optional) ────────────────────────────────────────────────────────────
# Set to "false" only for local dev with self-signed certs
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
